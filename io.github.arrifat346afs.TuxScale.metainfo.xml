<component type="desktop-application">
  <id>io.github.arrifat346afs.TuxScale</id>
  <name>TuxScale</name>
  <summary>AI-powered video upscaling for Linux</summary>

  <url type="homepage">https://github.com/arrifat346afs/TuxScale</url>
  <url type="bugtracker">https://github.com/arrifat346afs/TuxScale/issues</url>
